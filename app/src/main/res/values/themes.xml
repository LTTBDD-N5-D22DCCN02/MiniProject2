<resources>
    <style name="Theme.MovieTicketApp" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorOnBackground">#FFFFFF</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/colorBackground</item>

        <!-- ✅ Fix màu chữ toàn app -->
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:editTextColor">#FFFFFF</item>
        <item name="android:textColorHint">#777777</item>

        <!-- ✅ Fix TextInputLayout / SearchView trên nền tối -->
        <item name="editTextStyle">@style/AppEditTextStyle</item>
    </style>

    <!-- Style chung cho tất cả EditText -->
    <style name="AppEditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textColorHint">#777777</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="Theme.MovieTicketApp.Splash" parent="Theme.MovieTicketApp">
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
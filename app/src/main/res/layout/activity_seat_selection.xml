<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorSurface"
        android:title="Chọn ghế ngồi" />

    <!-- Screen indicator -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="20dp"
        android:paddingBottom="8dp">

        <View android:layout_width="240dp"
            android:layout_height="4dp"
            android:background="@color/colorPrimary" />

        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="MÀN HÌNH"
            android:textColor="@color/colorPrimary"
            android:textSize="11sp"
            android:letterSpacing="0.2" />
    </LinearLayout>

    <!-- Seat grid -->
    <ScrollView android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <GridLayout
                android:id="@+id/grid_seats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center" />

            <!-- Legend -->
            <LinearLayout android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <View android:layout_width="24dp" android:layout_height="24dp"
                    android:background="@drawable/bg_seat_available"
                    android:layout_marginEnd="6dp" />
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trống"
                    android:textColor="@color/colorOnBackground"
                    android:layout_marginEnd="20dp" />

                <View android:layout_width="24dp" android:layout_height="24dp"
                    android:background="@drawable/bg_seat_selected"
                    android:layout_marginEnd="6dp" />
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã chọn"
                    android:textColor="@color/colorOnBackground"
                    android:layout_marginEnd="20dp" />

                <View android:layout_width="24dp" android:layout_height="24dp"
                    android:background="@drawable/bg_seat_booked"
                    android:layout_marginEnd="6dp" />
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã bán"
                    android:textColor="@color/colorOnBackground" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Summary -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/colorSurface"
        android:elevation="8dp">

        <TextView android:id="@+id/tv_selected_seats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chưa chọn ghế"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView android:id="@+id/tv_total_price"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tổng: 0 đ"
                android:textColor="@color/colorOnBackground"
                android:textSize="18sp" android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_confirm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiếp tục"
                android:enabled="false" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
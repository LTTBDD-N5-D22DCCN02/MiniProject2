<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ── HEADER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#1E1E1E">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏢 Rạp chiếu phim"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Chọn rạp để xem lịch chiếu"
                android:textColor="#AAAAAA"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ── DANH SÁCH RẠP ── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_theaters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false" />

        <!-- ── CHI TIẾT RẠP + LỊCH CHIẾU (ẩn mặc định) ── -->
        <LinearLayout
            android:id="@+id/layout_theater_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="8dp">

            <!-- Header rạp đang chọn -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#1E1E1E">

                <!-- Tên rạp -->
                <TextView
                    android:id="@+id/tv_selected_theater"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#E53935"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <!-- Địa chỉ -->
                <TextView
                    android:id="@+id/tv_theater_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp" />

                <!-- Tiêu đề lịch chiếu -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="8dp"
                    android:text="📅 Lịch chiếu"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- Chip chọn ngày -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_theater_dates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true" />

            </LinearLayout>

            <!-- Thông báo không có suất -->
            <TextView
                android:id="@+id/tv_no_showtime_theater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Không có suất chiếu cho ngày này"
                android:textColor="#777777"
                android:textSize="14sp"
                android:gravity="center"
                android:paddingTop="24dp"
                android:paddingBottom="24dp"
                android:visibility="gone" />

            <!-- Danh sách suất chiếu của rạp -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_theater_showtimes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>